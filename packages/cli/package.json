{
  "name": "@pp/cli",
  "version": "0.1.0",
  "private": false,
  "description": "Power Platform CLI for local project work with Dataverse, solutions, canvas apps, and flows.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "power-platform",
    "dataverse",
    "cli",
    "agents"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "pp": "./dist/index.cjs"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --clean",
    "build:standalone": "tsup --config tsup.config.standalone.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepare": "pnpm build",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.ts"
  },
  "pkg": {
    "scripts": "dist-standalone/index.cjs",
    "assets": [],
    "outputPath": "dist-bin"
  },
  "dependencies": {
    "@pp/artifacts": "workspace:*",
    "@pp/auth": "workspace:*",
    "@pp/canvas": "workspace:*",
    "@pp/config": "workspace:*",
    "@pp/dataverse": "workspace:*",
    "@pp/diagnostics": "workspace:*",
    "@pp/flow": "workspace:*",
    "@pp/http": "workspace:*",
    "@pp/mcp": "workspace:*",
    "@pp/model": "workspace:*",
    "@pp/sharepoint": "workspace:*",
    "@pp/solution": "workspace:*",
    "playwright-core": "^1.52.0",
    "yaml": "^2.7.1"
  }
}

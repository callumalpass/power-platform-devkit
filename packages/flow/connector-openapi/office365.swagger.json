{
  "swagger": "2.0",
  "paths": {
    "/mail/send": {
      "post": {
        "operationId": "SendEmailV2",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "emailMessage": {
                  "type": "object",
                  "required": ["To", "Subject", "Body"],
                  "properties": {
                    "To": { "type": "string" },
                    "Subject": { "type": "string" },
                    "Body": { "type": "string" }
                  }
                }
              }
            }
          }
        ]
      }
    },
    "/mail/messages/{messageId}": {
      "get": {
        "operationId": "GetEmailV2",
        "parameters": [
          { "name": "messageId", "in": "path", "required": true, "type": "string" },
          { "name": "mailboxAddress", "in": "query", "type": "string" },
          { "name": "includeAttachments", "in": "query", "type": "boolean" },
          { "name": "internetMessageId", "in": "query", "type": "string" },
          { "name": "extractSensitivityLabel", "in": "query", "type": "boolean" },
          { "name": "fetchSensitivityLabelMetadata", "in": "query", "type": "boolean" }
        ]
      },
      "delete": {
        "operationId": "DeleteEmail_V2",
        "parameters": [
          { "name": "messageId", "in": "path", "required": true, "type": "string" },
          { "name": "mailboxAddress", "in": "query", "type": "string" }
        ]
      }
    },
    "/mail/messages/{messageId}/move": {
      "post": {
        "operationId": "MoveV2",
        "parameters": [
          { "name": "messageId", "in": "path", "required": true, "type": "string" },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["folderPath"],
              "properties": {
                "folderPath": { "type": "string" },
                "mailboxAddress": { "type": "string" }
              }
            }
          }
        ]
      }
    },
    "/mail/messages/{messageId}/read": {
      "post": {
        "operationId": "MarkAsRead_V3",
        "parameters": [
          { "name": "messageId", "in": "path", "required": true, "type": "string" },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["isRead"],
              "properties": {
                "mailboxAddress": { "type": "string" },
                "isRead": { "type": "boolean" }
              }
            }
          }
        ]
      }
    },
    "/calendar/events": {
      "post": {
        "operationId": "V4CalendarPostItem",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["table", "subject", "start", "end", "timeZone"],
              "properties": {
                "table": { "type": "string" },
                "subject": { "type": "string" },
                "start": { "type": "string" },
                "end": { "type": "string" },
                "timeZone": { "type": "string" },
                "requiredAttendees": { "type": "string" },
                "optionalAttendees": { "type": "string" }
              }
            }
          }
        ]
      }
    },
    "/calendar/events/{id}": {
      "patch": {
        "operationId": "V4CalendarPatchItem",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": ["table", "subject", "start", "end", "timeZone"],
              "properties": {
                "table": { "type": "string" },
                "subject": { "type": "string" },
                "start": { "type": "string" },
                "end": { "type": "string" },
                "timeZone": { "type": "string" },
                "requiredAttendees": { "type": "string" },
                "optionalAttendees": { "type": "string" }
              }
            }
          }
        ]
      }
    }
  }
}

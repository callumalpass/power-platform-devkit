{
  "name": "@pp/mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pp-mcp": "./dist/server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/server.ts --format esm,cjs --clean",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@pp/analysis": "workspace:*",
    "@pp/auth": "workspace:*",
    "@pp/canvas": "workspace:*",
    "@pp/config": "workspace:*",
    "@pp/dataverse": "workspace:*",
    "@pp/deploy": "workspace:*",
    "@pp/diagnostics": "workspace:*",
    "@pp/model": "workspace:*",
    "@pp/project": "workspace:*",
    "@pp/solution": "workspace:*",
    "yaml": "^2.8.1",
    "zod": "^3.24.2"
  }
}

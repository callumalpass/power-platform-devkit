{
  "name": "pp",
  "version": "0.1.0",
  "description": "CLI, MCP server, and browser UI for working with Microsoft Power Platform.",
  "type": "module",
  "license": "UNLICENSED",
  "private": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pp": "./dist/index.cjs",
    "pp-mcp": "./dist/mcp-server.js",
    "pp-ui": "./dist/ui-launcher.cjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.7.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js",
      "require": "./dist/mcp.cjs"
    },
    "./mcp-server": {
      "types": "./dist/mcp-server.d.ts",
      "import": "./dist/mcp-server.js",
      "require": "./dist/mcp-server.cjs"
    }
  },
  "scripts": {
    "build:ui-vendor": "node scripts/build-ui-vendor.mjs",
    "build:ui-client": "node scripts/build-ui-client.mjs",
    "build": "pnpm run build:ui-vendor && pnpm run build:ui-client && tsup src/index.ts src/mcp.ts src/mcp-server.ts src/ui-launcher.ts --format esm,cjs --dts --clean",
    "prepack": "pnpm run build",
    "build:sea": "pnpm run build && node scripts/build-sea.mjs",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "clean:test": "node -e \"require('node:fs').rmSync('.tmp-test',{recursive:true,force:true})\"",
    "test": "pnpm run clean:test && tsc -p tsconfig.test.json && node --test .tmp-test/test/**/*.test.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@azure/msal-node": "^5.0.6",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@lezer/common": "^1.5.1",
    "@lezer/highlight": "^1.2.3",
    "@lezer/lr": "^1.4.8",
    "@lezer/xml": "^1.0.6",
    "@marijn/find-cluster-break": "^1.0.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@replit/codemirror-vim": "^6.3.0",
    "codemirror": "^6.0.2",
    "crelt": "^1.0.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "style-mod": "^4.1.3",
    "w3c-keyname": "^2.2.8",
    "yaml": "^2.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.25.3",
    "postject": "^1.0.0-alpha.6",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  }
}

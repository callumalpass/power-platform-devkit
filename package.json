{
  "name": "pp",
  "version": "0.2.1",
  "description": "CLI, setup manager, MCP server, and desktop app for working with Microsoft Power Platform.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pp": "./dist/cli.cjs",
    "pp-mcp": "./dist/mcp-server.js",
    "pp-setup": "./dist/setup.js"
  },
  "files": [
    "dist",
    "!dist/desktop",
    "docs/api-stability.md",
    "docs/library.md",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.7.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js",
      "require": "./dist/mcp.cjs"
    },
    "./mcp-server": {
      "types": "./dist/mcp-server.d.ts",
      "import": "./dist/mcp-server.js",
      "require": "./dist/mcp-server.cjs"
    },
    "./accounts": {
      "types": "./dist/accounts.d.ts",
      "import": "./dist/accounts.js",
      "require": "./dist/accounts.cjs"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js",
      "require": "./dist/api.cjs"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js",
      "require": "./dist/auth.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js",
      "require": "./dist/config.cjs"
    },
    "./dataverse": {
      "types": "./dist/dataverse.d.ts",
      "import": "./dist/dataverse.js",
      "require": "./dist/dataverse.cjs"
    },
    "./diagnostics": {
      "types": "./dist/diagnostics.d.ts",
      "import": "./dist/diagnostics.js",
      "require": "./dist/diagnostics.cjs"
    },
    "./environments": {
      "types": "./dist/environments.d.ts",
      "import": "./dist/environments.js",
      "require": "./dist/environments.cjs"
    },
    "./fetchxml-language": {
      "types": "./dist/fetchxml-language.d.ts",
      "import": "./dist/fetchxml-language.js",
      "require": "./dist/fetchxml-language.cjs"
    },
    "./flow-language": {
      "types": "./dist/flow-language.d.ts",
      "import": "./dist/flow-language.js",
      "require": "./dist/flow-language.cjs"
    },
    "./request": {
      "types": "./dist/request.d.ts",
      "import": "./dist/request.js",
      "require": "./dist/request.cjs"
    },
    "./experimental/canvas-authoring": {
      "types": "./dist/experimental/canvas-authoring.d.ts",
      "import": "./dist/experimental/canvas-authoring.js",
      "require": "./dist/experimental/canvas-authoring.cjs"
    }
  },
  "scripts": {
    "build:desktop": "node scripts/build-desktop.mjs",
    "build:version": "node -e \"const v=require('./package.json').version;require('fs').writeFileSync('src/version.ts','// Generated at build time. Do not edit manually.\\nexport const VERSION = '+JSON.stringify(v)+';\\n')\"",
    "build": "pnpm run build:version && tsup src/index.ts src/cli.ts src/accounts.ts src/api.ts src/auth.ts src/client.ts src/config.ts src/dataverse.ts src/diagnostics.ts src/environments.ts src/experimental/canvas-authoring.ts src/fetchxml-language.ts src/flow-language.ts src/mcp.ts src/mcp-server.ts src/request.ts src/setup.ts --format esm,cjs --dts --clean && pnpm run build:desktop",
    "prepack": "pnpm run build",
    "build:sea": "pnpm run build && node scripts/build-sea.mjs",
    "dev:desktop": "node scripts/dev-desktop.mjs",
    "package:desktop": "pnpm run build && node scripts/package-desktop.mjs",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "clean:test": "node -e \"require('node:fs').rmSync('.tmp-test',{recursive:true,force:true})\"",
    "test": "pnpm run clean:test && tsc -p tsconfig.test.json && node --test .tmp-test/test/**/*.test.js",
    "test:package": "node test/package-smoke.mjs",
    "test:e2e:desktop": "pnpm run build && node scripts/run-desktop-e2e.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@azure/msal-node": "^5.0.6",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "jq-wasm": "1.1.0-jq-1.8.1",
    "yaml": "^2.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.3",
    "monaco-editor": "^0.55.1",
    "monaco-vim": "^0.4.4",
    "postject": "^1.0.0-alpha.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  }
}

{
  "actions": [
    {
      "action": "create",
      "kind": "config",
      "path": "<TMP_DIR>/pp.config.yaml"
    },
    {
      "action": "create",
      "kind": "directory",
      "path": "<TMP_DIR>/apps"
    },
    {
      "action": "create",
      "kind": "directory",
      "path": "<TMP_DIR>/flows"
    },
    {
      "action": "create",
      "kind": "directory",
      "path": "<TMP_DIR>/solutions"
    },
    {
      "action": "create",
      "kind": "directory",
      "path": "<TMP_DIR>/docs"
    },
    {
      "action": "create",
      "kind": "directory",
      "path": "<TMP_DIR>/artifacts/solutions"
    }
  ],
  "config": {
    "assets": {
      "apps": "apps",
      "docs": "docs",
      "flows": "flows",
      "solutions": "solutions"
    },
    "defaults": {
      "environment": "sandbox",
      "solution": "CoreLifecycle",
      "stage": "dev"
    },
    "docs": {
      "paths": [
        "docs"
      ]
    },
    "name": "HarnessDemo",
    "providerBindings": {
      "primaryDataverse": {
        "description": "Primary Dataverse environment alias for this project",
        "kind": "dataverse",
        "target": "sandbox"
      }
    },
    "solutions": {
      "CoreLifecycle": {
        "environment": "sandbox",
        "uniqueName": "CoreLifecycle"
      }
    },
    "topology": {
      "defaultStage": "dev",
      "stages": {
        "dev": {
          "environment": "sandbox",
          "solution": "CoreLifecycle"
        }
      }
    }
  },
  "configExists": false,
  "configPath": "<TMP_DIR>/pp.config.yaml",
  "created": [
    "<TMP_DIR>/apps",
    "<TMP_DIR>/flows",
    "<TMP_DIR>/solutions",
    "<TMP_DIR>/docs",
    "<TMP_DIR>/artifacts/solutions",
    "<TMP_DIR>/pp.config.yaml"
  ],
  "layout": {
    "bundleFirstConvention": "If the repo primarily tracks exported packages, keep packaged solution zips under `artifacts/solutions/CoreLifecycle.zip` instead of mixing them into `solutions/`.",
    "recommendedBundlePath": "artifacts/solutions/CoreLifecycle.zip",
    "scaffoldedAssetRoots": [
      "apps",
      "flows",
      "solutions",
      "docs"
    ],
    "scaffoldProfile": "source-first",
    "sourceFirstConvention": "The default scaffold is source-first: keep editable solution source in `solutions/` alongside `apps/`, `flows/`, and `docs/`."
  },
  "overwritten": [],
  "root": "<TMP_DIR>",
  "untouched": []
}

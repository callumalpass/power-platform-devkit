{
  "name": "Home",
  "controls": [
    {
      "name": "Layout",
      "templateName": "groupContainer",
      "templateVersion": "1.0.0",
      "properties": {
        "Width": 640,
        "Height": 480
      },
      "children": [
        {
          "name": "Header",
          "templateName": "Label",
          "templateVersion": "1.0.0",
          "properties": {
            "TextFormula": "\"Account workspace\"",
            "X": 16,
            "Y": 12
          },
          "children": []
        },
        {
          "name": "AccountCard",
          "templateName": "groupContainer",
          "templateVersion": "1.0.0",
          "properties": {
            "X": 16,
            "Y": 56,
            "Width": 608,
            "Height": 180
          },
          "children": [
            {
              "name": "AccountTitle",
              "templateName": "modernText",
              "templateVersion": "1.0.0",
              "properties": {
                "TextFormula": "If(IsBlank(varSelectedAccount), \"Select an account\", varSelectedAccount.'Account Name')",
                "X": 12,
                "Y": 12
              },
              "children": []
            },
            {
              "name": "PrimaryContact",
              "templateName": "Label",
              "templateVersion": "1.0.0",
              "properties": {
                "TextFormula": "LookUp(Contacts, Contact = varSelectedAccount.'Primary Contact', 'Full Name')",
                "X": 12,
                "Y": 52
              },
              "children": []
            },
            {
              "name": "ApprovalBadge",
              "templateName": "Label",
              "templateVersion": "1.0.0",
              "properties": {
                "TextFormula": "\"Approved order\"",
                "VisibleFormula": "varSelectedOrder.Status = 'Order Status'.Approved",
                "X": 12,
                "Y": 92
              },
              "children": []
            },
            {
              "name": "SaveButton",
              "templateName": "Button",
              "templateVersion": "1.0.0",
              "properties": {
                "TextFormula": "\"Sync account\"",
                "OnSelectFormula": "Patch(Accounts, varSelectedAccount, { 'Preferred Contact': LookUp(Contacts, Email = User().Email), Category: 'Account Category'.Preferred, 'Region Code': Regions.East })",
                "X": 12,
                "Y": 132
              },
              "children": []
            }
          ]
        },
        {
          "name": "OrderSummary",
          "templateName": "Label",
          "templateVersion": "1.0.0",
          "properties": {
            "TextFormula": "Concat(Filter(Orders, Account.Account = varSelectedAccount.Account), ProductName, \", \")",
            "X": 16,
            "Y": 260
          },
          "children": []
        }
      ]
    }
  ]
}
